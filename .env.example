VITE_API_BASE_URL=http://localhost:8000

# Backend (see backend/app/config.py)
# AUDIO2MIDI_UPLOADS=./uploads
# AUDIO2MIDI_OUTPUTS=./outputs
# AUDIO2MIDI_JOBS=./jobs
# AUDIO2MIDI_DATABASE_URL=sqlite:///./pianist.db
# AUDIO2MIDI_AUTH_SECRET=dev-secret-change-me
# AUDIO2MIDI_WORKER_SECRET=dev-worker-secret
# AUDIO2MIDI_MAX_UPLOAD_MB=60
# AUDIO2MIDI_LOG_LEVEL=INFO

# Worker integration (Render backend -> Hetzner worker)
# AUDIO2MIDI_PUBLIC_API_URL=https://your-backend.onrender.com
# AUDIO2MIDI_WORKER_URL=https://your-worker.example.com
# AUDIO2MIDI_WORKER_API_KEY=optional-shared-api-key
# AUDIO2MIDI_USE_BACKGROUND_TASKS=true

# MIDI worker (see services/midi-worker/README.md)
# MIDI_WORKER_REDIS_URL=redis://localhost:6379/0
# MIDI_WORKER_WORKER_SECRET=dev-worker-secret
# MIDI_WORKER_API_KEY=optional-shared-api-key
# MIDI_WORKER_ARTIFACT_DIR=./artifacts
